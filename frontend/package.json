{
	"name": "dollarsandlife",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"predev": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && node scripts/generate-content-language-manifest.cjs",
		"prebuild": "node scripts/generate-content-language-manifest.cjs",
		"dev": "node node_modules/next/dist/bin/next dev",
		"build": "node node_modules/next/dist/bin/next build && node sitemap-generator/mongo-generate-sitemap.cjs",
		"start": "node node_modules/next/dist/bin/next start",
		"lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"generate-sitemap": "node dist/generate-sitemap.js",
		"generate-content-language-manifest": "node scripts/generate-content-language-manifest.cjs"
	},
	"dependencies": {
		"@emailjs/browser": "^4.4.1",
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-brands-svg-icons": "^7.2.0",
		"@fortawesome/react-fontawesome": "^3.3.1",
		"@types/react-google-recaptcha": "^2.1.9",
		"browser-image-compression": "^2.0.2",
		"dompurify": "^3.4.2",
		"dotenv": "^17.4.2",
		"firebase": "^12.12.1",
		"fs-extra": "^11.3.4",
		"html-react-parser": "^6.0.1",
		"jose": "^6.2.3",
		"jsdom": "^29.1.1",
		"next": "15.5.15",
		"react": "^19.2.5",
		"react-adsense": "^0.1.0",
		"react-device-detect": "^2.2.3",
		"react-dom": "^19.2.5",
		"react-firebase-hooks": "https://registry.npmjs.org/react-firebase-hooks/-/react-firebase-hooks-5.1.1.tgz",
		"react-google-recaptcha": "^3.1.0",
		"react-hot-toast": "^2.6.0",
		"sitemap": "^9.0.1",
		"styled-components": "^6.4.1"
	},
	"devDependencies": {
		"@eslint/config-array": "^0.23.5",
		"@eslint/object-schema": "^3.0.5",
		"@next/bundle-analyzer": "^15.3.8",
		"@types/dompurify": "^3.2.0",
		"@types/jsdom": "^28.0.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"babel-plugin-styled-components": "^2.1.4",
		"cross-env": "^10.1.0",
		"eslint": "^10.2.1",
		"eslint-plugin-react-hooks": "^7.1.1",
		"mongodb": "^7.2.0",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"protobufjs": "7.5.5",
		"lodash": "4.18.1",
		"flatted": "3.4.2",
		"picomatch": "2.3.2"
	},
	"sideEffects": [
		"**/*.css"
	],
	"browserslist": [
		"chrome >= 93",
		"firefox >= 90",
		"safari >= 15",
		"edge >= 93",
		"ios_saf >= 15",
		"not dead"
	],
	"optionalDependencies": {
		"@next/swc-wasm-nodejs": "*"
	}
}
